    {
      "parameters": {
        "jsCode": "const searchResponse = $('Search LinkedIn Prospects').item.json;\nconst prospects = searchResponse[0]?.items || searchResponse.items || [];\n\n// Sheet se existing URLs\nconst existingRows = $('Get Existing Sheet Data').all();\nconst existingUrls = existingRows.map(r => r.json['LinkedIn URL']).filter(Boolean);\n\n// Unipile se already-sent invites (LinkedIn ki actual pending list)\nlet sentInvites = [];\ntry {\n  const sentResponse = $('Get Sent Invitations').item.json;\n  sentInvites = (sentResponse.items || []).map(i => i.provider_id || i.invited_user_id);\n} catch(e) {\n  sentInvites = [];\n}\n\nconst newProspects = prospects.filter(p => {\n  const profileUrl = p.public_profile_url || p.profile_url || '';\n  const alreadyInSheet = existingUrls.includes(profileUrl);\n  const alreadyInvitedOnLinkedIn = sentInvites.includes(p.id);\n  return profileUrl && !alreadyInSheet && !alreadyInvitedOnLinkedIn;\n});\n\nreturn newProspects.map(p => ({\n  json: {\n    name: p.name || '',\n    title: p.headline || '',\n    company: '',\n    linkedin_url: p.public_profile_url || p.profile_url || '',\n    provider_id: p.id || '',\n    location: p.location || '',\n    network_distance: p.network_distance || '',\n    member_urn: p.member_urn || ''\n  }\n}));"
      },
      "id": "17c0846d-ff4d-48ff-bc46-d63ac278ac6c",
      "name": "Filter New Prospects Only",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2032,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "// Get ALL AI responses and ALL prospects\nconst aiResponses = $('AI Score Prospect').all();\nconst prospects = $('Filter New Prospects Only').all();\n\n// Pair each AI response with its matching prospect by index\nconst results = aiResponses.map((aiItem, index) => {\n  const content = aiItem.json.choices?.[0]?.message?.content || '{}';\n  \n  let parsed;\n  try {\n    const match = content.match(/\\{[\\s\\S]*\\}/);\n    parsed = JSON.parse(match ? match[0] : '{}');\n  } catch(e) {\n    parsed = { score: 5, reason: 'parse error', should_contact: true };\n  }\n\n  const prospect = prospects[index]?.json || {};\n\n  return {\n    json: {\n      ...prospect,\n      ai_score: parsed.score || 5,\n      ai_reason: parsed.reason || '',\n      should_contact: parsed.should_contact !== false\n    }\n  };\n});\n\nreturn results;"
      },
