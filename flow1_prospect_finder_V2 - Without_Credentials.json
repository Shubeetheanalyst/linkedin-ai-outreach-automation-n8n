        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a B2B lead qualifier for an automation agency. Score prospects 1-10 on how likely they NEED automation services. High score: business owners, founders, operations managers, CEOs, people running agencies. Low score: students, developers, job seekers, other automation agencies (they are competitors not clients). Return ONLY valid JSON: {\\\"score\\\": 7, \\\"reason\\\": \\\"brief reason\\\", \\\"should_contact\\\": true}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ 'Prospect: ' + $json.name + ', Headline: ' + $json.title + ', Location: ' + $json.location + '. Score this person as a potential automation services client.' }}\"\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 150\n}",
