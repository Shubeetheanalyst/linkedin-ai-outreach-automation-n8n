    {
      "parameters": {
        "jsCode": "const inputItems = $('Quality Filter (Score >= 6)').all();\nconst errorItems = $('Send LinkedIn Connection Request').all();\n\nreturn inputItems.map((item, index) => {\n  const status = errorItems[index]?.json?.error\n    ? 'Failed'\n    : 'Connection Sent';\n\n  return {\n    json: {\n      ...item.json,\n      connection_status: status,\n      date_sent: new Date().toISOString().split('T')[0],\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
